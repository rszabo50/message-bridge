# Copy to a local shell/export mechanism if needed.
# Do not put real webhook URLs in this file.

# Real webhook integration tests are opt-in.
# Each missing variable causes that provider's test to be skipped.
MESSAGE_BRIDGE_SLACK_WEBHOOK_URL=
MESSAGE_BRIDGE_MATTERMOST_WEBHOOK_URL=
MESSAGE_BRIDGE_DISCORD_WEBHOOK_URL=
MESSAGE_BRIDGE_TEAMS_WEBHOOK_URL=

# Optional label included in real webhook integration test messages.
MESSAGE_BRIDGE_TEST_LABEL=local
